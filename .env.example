# PostgreSQL (tùy chọn). Nếu không set, app dùng bộ nhớ trong (in-memory); dữ liệu mất khi restart.
# Deploy lên Render với DB: dùng Internal URL từ Render Postgres.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Session encryption (bắt buộc khi dùng session)
SESSION_SECRET=your_session_secret_here